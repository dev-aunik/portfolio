# ──────────────────────────────────────────────────────────────────────────────
# Portfolio — Local Development Environment
# ──────────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
BACKEND_PORT=8080
ALLOWED_ORIGINS=http://localhost:4200

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio
DB_USER=portfolio
DB_PASSWORD=portfolio_secret
DB_SSLMODE=disable
DATABASE_URL=postgres://portfolio:portfolio_secret@localhost:5432/portfolio?sslmode=disable

# ─── Cache (Redis) ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0
REDIS_URL=redis://:redis_secret@localhost:6379/0
CACHE_ARTICLES_TTL=300
CACHE_ARTICLE_TTL=600

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=dev_local_secret_change_in_production_32chars_min
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_HOURS=168

ADMIN_EMAIL=admin@portfolio.local
ADMIN_PASSWORD=admin123

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_ADMIN=1000
RATE_LIMIT_CONTACT=5

# ─── SMTP — optional ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
NOTIFY_EMAIL=your@email.com

# ─── Log ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
