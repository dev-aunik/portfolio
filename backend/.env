# ──────────────────────────────────────────────────────────────────────────────
# Portfolio — Local Development Environment
# ──────────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
BACKEND_PORT=8080
ALLOWED_ORIGINS=http://localhost:4200

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio
DB_USER=portfolio
DB_PASSWORD=portfolio_secret
DB_SSLMODE=disable
DATABASE_URL=postgres://portfolio:portfolio_secret@localhost:5432/portfolio?sslmode=disable

# ─── Cache (Redis) ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0
REDIS_URL=redis://:redis_secret@localhost:6379/0
CACHE_ARTICLES_TTL=300
CACHE_ARTICLE_TTL=600

# ─── Search (Typesense) — optional, server starts without it ──────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=typesense_secret
TYPESENSE_COLLECTION_ARTICLES=articles

# ─── Message Queue (RabbitMQ) — optional ─────────────────────────────────────
RABBITMQ_URL=amqp://admin:rabbitmq_secret@localhost:5672/portfolio
RABBITMQ_EXCHANGE=portfolio.events
RABBITMQ_QUEUE_CONTACT=contact.submissions

# ─── Event Streaming (Kafka) — optional ──────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_AUDIT=portfolio.audit
KAFKA_TOPIC_CONTACT=portfolio.contact
KAFKA_GROUP_ID=portfolio-consumer

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=dev_local_secret_change_in_production_32chars_min
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_HOURS=168

ADMIN_EMAIL=admin@portfolio.local
ADMIN_PASSWORD=admin123

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_ADMIN=1000
RATE_LIMIT_CONTACT=5

# ─── SMTP — optional ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
NOTIFY_EMAIL=your@email.com

# ─── Log ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
